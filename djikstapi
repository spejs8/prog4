    // Приоритетна редица каде го чуваме најмалиот множител на простите броеви
    priority_queue<Node, vector<Node>, greater<Node>> pq;

    cout << "Прости броеви до " << limit << ":\n2 ";
    pq.push({BigInt(4), BigInt(2)});

    for (int i = 3; i <= limit; i++) {
        BigInt current(i);

        if (current < pq.top().multiple) {
            // Ако i е помало од најмалиот множител во редицата, тогаш i е прост број
            cout << i << " ";
